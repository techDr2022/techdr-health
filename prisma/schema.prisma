generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
}

enum PlanType {
  INDIVIDUAL
  CLINIC
  HOSPITAL
}

enum SubStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RoomStatus {
  WAITING
  ACTIVE
  ENDED
  MISSED
}

enum ConsultType {
  VIDEO
  AUDIO
  CHAT
}

enum PayStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum WeekDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  phone             String?         @unique
  passwordHash      String
  role              Role            @default(PATIENT)
  name              String
  avatarUrl         String?
  isVerified        Boolean         @default(false)
  phoneVerified     Boolean         @default(false)
  emailVerified     Boolean         @default(false)
  authProvider      String          @default("email")
  lastLoginAt       DateTime?
  loginCount        Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  doctorProfile     DoctorProfile?
  bookingsAsPatient Booking[]       @relation("PatientBookings")
  sessions          Session[]
  authSessions      AuthSession[]
  blogPosts         BlogPost[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OtpRecord {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  device       String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
}

model DoctorProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug            String         @unique
  displayName     String
  photoUrl        String?
  coverPhotoUrl   String?

  specialty       String
  subSpecialties  String[]
  credentials     String
  medRegNumber    String
  experience      Int
  education       Json
  hospitalAffils  String[]
  bio             String?        @db.Text
  languages       String[]
  conditions      String[]
  awards          Json?

  consultFee      Int
  followUpFee     Int            @default(0)
  consultDuration Int            @default(20)
  consultTypes    ConsultType[]

  approvalStatus  ApprovalStatus @default(PENDING)
  isVisible       Boolean        @default(false)
  rejectionReason String?

  medRegCertUrl   String?
  degreeDocUrl    String?
  govIdUrl        String?

  subscription    Subscription?
  timings         DoctorTiming[]
  bookings        Booking[]      @relation("DoctorBookings")
  reviews         Review[]

  metaTitle       String?
  metaDesc        String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model DoctorTiming {
  id       String        @id @default(cuid())
  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  day      WeekDay
  isOpen   Boolean       @default(true)
  slots    TimeSlot[]

  @@unique([doctorId, day])
}

model TimeSlot {
  id        String       @id @default(cuid())
  timingId  String
  timing    DoctorTiming @relation(fields: [timingId], references: [id], onDelete: Cascade)
  startTime String
  endTime   String
  isBooked  Boolean      @default(false)
}

model Subscription {
  id                  String        @id @default(cuid())
  doctorId            String        @unique
  doctor              DoctorProfile @relation(fields: [doctorId], references: [id])

  plan                PlanType
  status              SubStatus     @default(PENDING_PAYMENT)
  priceINR            Int

  purchasedAt         DateTime?
  activatedAt         DateTime?
  expiresAt           DateTime?
  cancelledAt         DateTime?

  cashfreeOrderId     String?       @unique
  cashfreePaymentId   String?
  cashfreeSignature   String?

  renewalReminderSent Boolean       @default(false)
  expiredEmailSent    Boolean       @default(false)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Booking {
  id                 String        @id @default(cuid())
  patientId          String
  patient            User          @relation("PatientBookings", fields: [patientId], references: [id])
  doctorId           String
  doctor             DoctorProfile @relation("DoctorBookings", fields: [doctorId], references: [id])

  scheduledAt        DateTime
  endsAt             DateTime
  consultType        ConsultType
  status             BookingStatus @default(UPCOMING)

  consultFee         Int
  platformFeeINR     Int
  doctorPayoutINR    Int
  gstINR             Int
  totalPatientPays   Int

  payStatus          PayStatus     @default(PENDING)
  cashfreeOrderId    String?
  cashfreePaymentId  String?

  payoutStatus       PayoutStatus  @default(PENDING)
  payoutDate         DateTime?
  payoutRef          String?

  meetingLink        String?
  notes              String?       @db.Text
  prescription       Json?
  diagnosis          String?

  followUpDate       DateTime?

  cancellationReason String?
  cancelledBy        String?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  review             Review?
  earnings           PlatformEarning?
  consultationRoom   ConsultationRoom?
  prescriptionRecord Prescription?
}

model ConsultationRoom {
  id              String     @id @default(cuid())
  bookingId       String     @unique
  booking         Booking    @relation(fields: [bookingId], references: [id])

  twilioRoomSid   String?    @unique
  twilioRoomName  String     @unique
  status          RoomStatus @default(WAITING)

  recordingSid    String?
  recordingUrl    String?
  recordingStatus String?

  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int?

  chatLog         Json?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Prescription {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  booking       Booking   @relation(fields: [bookingId], references: [id])
  patientId     String
  doctorId      String

  diagnosis     String
  medicines     Json
  instructions  String?   @db.Text
  followUpDate  DateTime?

  pdfUrl        String?
  sentAt        DateTime?
  viewedAt      DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Review {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id])
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  rating      Int
  comment     String?       @db.Text
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
}

model PlatformEarning {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id])
  platformFeeINR Int
  gstINR         Int
  totalEarned    Int
  month          Int
  year           Int
  createdAt      DateTime @default(now())
}

model BlogPost {
  id           String         @id @default(cuid())
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title        String
  slug         String         @unique
  excerpt      String         @db.Text
  body         String         @db.Text
  category     String
  specialtySlug String?
  coverImage   String
  readingMinutes Int          @default(5)
  status       BlogPostStatus @default(DRAFT)
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, publishedAt])
}
